   PART 3
=================================== */

/* ---------- RESEARCH ---------- */

.research{

    padding:90px 20px;

    background:#f8f8f8;

    text-align:center;

}

.research h2{

    font-size:36px;

    margin-bottom:40px;

}

.cards{

    max-width:1200px;

    margin:auto;

    display:grid;

    grid-template-columns:repeat(auto-fit,minmax(280px,1fr));

    gap:25px;

}

.card{

    background:white;

    padding:30px;

    border-radius:15px;

    box-shadow:0 8px 20px rgba(0,0,0,.12);

    transition:.35s;

}

.card:hover{

    transform:translateY(-10px);

    box-shadow:0 15px 35px rgba(0,0,0,.20);

}

.card h3{

    color:#b8860b;

    margin-bottom:15px;

}

.card p{

    line-height:1.7;

}

/* ---------- TRAINING ---------- */

.training{

    padding:90px 20px;

    background:white;

    text-align:center;

}

.training h2{

    font-size:36px;

    margin-bottom:30px;

}

.training ul{

    list-style:none;

    max-width:450px;

    margin:auto;

}

.training li{

    background:#111;

    color:white;

    margin:15px 0;

   /* ===================================
