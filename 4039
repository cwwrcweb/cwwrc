/* ---------- FOOTER ---------- */

footer{

    background:#111;

    color:white;

    text-align:center;

    padding:35px 20px;

}

footer p{

    margin:8px 0;

}

/* ---------- SECTION TITLE ---------- */

section h2{

    position:relative;

    display:inline-block;

}

section h2::after{

    content:"";

    display:block;

    width:70px;

    height:4px;

    margin:12px auto 0;

    background:#d4af37;

    border-radius:5px;

}

/* ---------- IMAGE ---------- */

img{

    max-width:100%;

    display:block;

}

/* ---------- SCROLLBAR ---------- */

::-webkit-scrollbar{

    width:10px;

}

::-webkit-scrollbar-track{

    background:#f1f1f1;

}

::-webkit-scrollbar-thumb{

    background:#b8860b;

    border-radius:20px;

}

::-webkit-scrollbar-thumb:hover{

    background:#d4af37;

}

/* ---------- TEXT SELECTION ---------- */

::selection{

    background:#d4af37;

    color:white;

}

/* ---------- MOBILE ---------- */

@media(max-width:768px){

    header{

        flex-wrap:wrap;

        padding:15px;

    }

    .logo img{

        width:55px;

    }

    header h1{

        font-size:18px;

        margin:10px 0;

    }

    .menu-toggle{

        display:block;

    }

    nav{

        display:none;

        width:100%;

        margin-top:20px;

    }

    nav.active{

        display:block;

    }

    nav ul{

        flex-direction:column;

        align-items:center;

        gap:15px;

    }

    .hero{

        padding:150px 20px 90px;

    }

    .hero h2{

        font-size:34px;

    }

    .hero p{

        font-size:18px;

    }

    .hero-buttons{

        flex-direction:column;

        align-items:center;

    }

    .btn{

        width:220px;

        margin:10px auto;

    }

    .cards{

        grid-template-columns:1fr;

    }

}

/* ---------- DESKTOP ---------- */

@media(min-width:769px){

    nav{

        display:block !important;

    }

}